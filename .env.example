MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?appName=<appname>
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?appName=<appname>
JWT_SECRET=your-secret-key-here
# Key used to encrypt sensitive account fields at rest (tax ID, home address).
# Any passphrase works; it is hashed to a 32-byte AES key. Keep it secret and
# stable — changing it makes previously encrypted data unreadable.
FIELD_ENCRYPTION_KEY=your-field-encryption-key-here
NODE_ENV=development
# Comma-separated list of allowed frontend origins for CORS.
CORS_ORIGIN=http://localhost:5173

# SMTP settings for invoice emails
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="CS308 Store" <your-email@gmail.com>
